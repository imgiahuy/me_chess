{
  "realm": "chess",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": true,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "chess-web",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:3005/*", "http://localhost:3000/*"],
      "webOrigins": ["http://localhost:3005", "http://localhost:3000"],
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "attributes": {
        "access.token.lifespan": "3600"
      }
    },
    {
      "clientId": "chess-api",
      "enabled": true,
      "publicClient": false,
      "secret": "chess-api-secret",
      "redirectUris": ["http://localhost:8085/*"],
      "webOrigins": ["http://localhost:8085"],
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "player",
        "description": "Regular chess player"
      },
      {
        "name": "admin",
        "description": "Chess administrator"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@chess.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "player"]
    }
  ]
}
